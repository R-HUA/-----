PORT=3000
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com

# true: generated images are saved, thumbnailed, then held for admin approval.
# false: generated images are saved and the upstream OpenAI response is returned immediately.
IMAGE_PROXY_REQUIRE_APPROVAL=false
IMAGE_PROXY_APPROVAL_HOLD_MS=300000
IMAGE_PROXY_UPSTREAM_TIMEOUT_MS=600000
IMAGE_PROXY_MAX_JSON_BODY_BYTES=1073741824
IMAGE_PROXY_MAX_MULTIPART_FILE_BYTES=52428800
IMAGE_PROXY_MAX_MULTIPART_FILES=8
IMAGE_PROXY_MAX_MULTIPART_FIELDS=100
IMAGE_PROXY_GENERATED_DOWNLOAD_TIMEOUT_MS=60000
IMAGE_PROXY_GENERATED_DOWNLOAD_MAX_BYTES=52428800
IMAGE_PROXY_ALLOW_PRIVATE_GENERATED_URLS=false

# Optional client-facing protection for /v1/images/*.
# When set, clients must send Authorization: Bearer <key> or x-api-key: <key>.
IMAGE_PROXY_CLIENT_API_KEYS=
IMAGE_PROXY_RATE_LIMIT_PER_MINUTE=0
IMAGE_PROXY_MAX_CONCURRENT_REQUESTS=0

IMAGE_PROXY_STORAGE_DIR=./storage
IMAGE_PROXY_GENERATED_DIR=./storage/generated
IMAGE_PROXY_THUMBNAIL_DIR=./storage/thumbnails
IMAGE_PROXY_INPUT_DIR=./storage/inputs
IMAGE_PROXY_DATA_FILE=./storage/data/history.json
IMAGE_PROXY_THUMBNAIL_WIDTH=384

# Protect /admin/* endpoints. If unset, admin endpoints are open for local development.
IMAGE_PROXY_ADMIN_TOKEN=change-me
